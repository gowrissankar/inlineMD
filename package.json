{
  "name": "inlinemd",
  "displayName": "inlineMD",
  "description": "Edit Markdown source inline — directly from the preview.",
  "publisher": "gowrissankar",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gowrissankar/inlineMD.git"
  },
  "bugs": {
    "url": "https://github.com/gowrissankar/inlineMD/issues"
  },
  "homepage": "https://github.com/gowrissankar/inlineMD#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "inlinemd.openPreview",
        "title": "inlineMD: Open Preview"
      }
    ],
    "customEditors": [
      {
        "viewType": "inlinemd.preview",
        "displayName": "inlineMD",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.0.0"
  }
}
